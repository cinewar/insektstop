// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  address   String?
  phone     String?
  facebook String?
  instagram String?
  youtube   String?
  about     String
  heroImage String
  heroText  String
  password  String
  resetToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  productId   Int            @unique
  active      Boolean        @default(true)
  name        String
  description String
  price       Float
  images      ProductImage[]
  orderItems  OrderItemProduct[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

type ProductImage {
  id  Int
  img String
}


enum ProcessStatus {
  pending
  in_progress
  completed
  cancelled
}

model Order {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  orderId      Int            @unique
  orderName    String
  orderItems   OrderProduct[]
  totalPrice   Float
  processStatus ProcessStatus?
  createrName  String
  createrEmail String
  createrPhone String
  createrAddress String
  messages Message[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum CreatorType {
  Customer
  Admin
}

type MessageImage {
  id  Int
  img String
}

model Message {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  orderRefId String       @db.ObjectId
  image     MessageImage?
  creator   CreatorType  @default(Customer)
  content   String?
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())

  order     Order        @relation(fields: [orderRefId], references: [id])
}

model OrderProduct {
  id       String              @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  orderRefId String            @db.ObjectId
  price    Float

  order    Order              @relation(fields: [orderRefId], references: [id])
  products OrderItemProduct[]
}

model OrderItemProduct {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  orderProductRefId String       @db.ObjectId
  productRefId      String       @db.ObjectId
  length   Int
  width    Int
  images   OrderProductImage[]

  orderProduct OrderProduct @relation(fields: [orderProductRefId], references: [id])
  product      Product      @relation(fields: [productRefId], references: [id])
}

type OrderProductImage {
  id  Int
  img String
}